rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email in ["polyglot.app2@gmail.com"];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['hostId', 'title', 'sourceLanguage', 'targetLanguages', 'status', 'createdAt']) &&
             data.hostId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.sourceLanguage is string && data.sourceLanguage.size() >= 2 && data.sourceLanguage.size() <= 5 &&
             data.targetLanguages is list && data.targetLanguages.size() <= 10 &&
             data.status in ['ACTIVE', 'ENDED'] &&
             data.createdAt is timestamp;
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['sessionId', 'role', 'language', 'joinedAt']) &&
             data.sessionId is string &&
             data.role in ['HOST', 'GUEST'] &&
             data.language is string && data.language.size() >= 2 && data.language.size() <= 5 &&
             (!('userId' in data) || data.userId == request.auth.uid) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 50)) &&
             data.joinedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['sessionId', 'senderId', 'type', 'sourceLanguage', 'sourceText', 'createdAt']) &&
             data.sessionId is string &&
             data.senderId is string &&
             data.type in ['BROADCAST', 'QUESTION', 'ANSWER', 'CONCIERGE'] &&
             data.sourceLanguage is string && data.sourceLanguage.size() >= 2 && data.sourceLanguage.size() <= 5 &&
             data.sourceText is string && data.sourceText.size() <= 2000 &&
             (!('translations' in data) || data.translations is map) &&
             data.createdAt is timestamp;
    }

    function sessionHostId(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId;
    }

    function isParticipantOwner(sessionId, participantId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/sessions/$(sessionId)/participants/$(participantId)) &&
             get(/databases/$(database)/documents/sessions/$(sessionId)/participants/$(participantId)).data.userId == request.auth.uid;
    }

    function canSendSessionMessage(sessionId, senderId) {
      return isAuthenticated() &&
             (
               sessionHostId(sessionId) == request.auth.uid ||
               senderId == request.auth.uid ||
               isParticipantOwner(sessionId, senderId)
             );
    }

    // ─── Users ──────────────────────────────────────────────────────────────

    // Plan / entitlements / trial fields are server-managed (Cloud Functions
    // via Stripe webhook, license-key redeem, trial quota). Client must never
    // touch them directly.
    function touchesProtectedUserField() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'plan',
        'planStatus',
        'planSource',
        'planExpiresAt',
        'planSyncedAt',
        'stripeCustomerId',
        'stripeSubscriptionId',
        'entitlements',
        'trial',
        'trialUsage',
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && !touchesProtectedUserField();
      allow delete: if false;
    }

    // ─── Admin-only collections ─────────────────────────────────────────────

    match /app_usage_daily/{docId} {
      allow read: if isAdmin();
      // Anonymous client telemetry. Validate the document shape to prevent
      // arbitrary writes; no auth required so first-open metrics still work.
      allow create, update: if
        request.resource.data.dayKey is string &&
        request.resource.data.dayKey.size() <= 16 &&
        request.resource.data.deviceId is string &&
        request.resource.data.deviceId.size() <= 64;
      allow delete: if false;
    }

    match /feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // License keys: Cloud Functions only (admin SDK bypasses rules).
    match /license_keys/{code} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Sessions and sub-collections ───────────────────────────────────────

    match /sessions/{sessionId} {
      // Anyone can read a session (needed for guests joining via link/code).
      allow read: if true;
      allow create: if isAuthenticated() &&
                    isValidSession(request.resource.data) &&
                    request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated() &&
                    isValidSession(request.resource.data) &&
                    resource.data.hostId == request.auth.uid &&
                    request.resource.data.hostId == resource.data.hostId;
      allow delete: if isAuthenticated() && resource.data.hostId == request.auth.uid;

      match /participants/{participantId} {
        allow read: if true;
        allow create: if isAuthenticated() &&
                      isValidParticipant(request.resource.data) &&
                      request.resource.data.sessionId == sessionId;
        allow update: if isAuthenticated() &&
                      isValidParticipant(request.resource.data) &&
                      request.resource.data.sessionId == sessionId &&
                      (
                        resource.data.userId == request.auth.uid ||
                        participantId == request.auth.uid ||
                        sessionHostId(sessionId) == request.auth.uid
                      );
        allow delete: if isAuthenticated() &&
                      (
                        resource.data.userId == request.auth.uid ||
                        participantId == request.auth.uid ||
                        sessionHostId(sessionId) == request.auth.uid
                      );
      }

      match /messages/{messageId} {
        allow read: if true;
        allow create: if isAuthenticated() &&
                      isValidMessage(request.resource.data) &&
                      request.resource.data.sessionId == sessionId &&
                      canSendSessionMessage(sessionId, request.resource.data.senderId);
        // Only the session host can update messages (e.g. attach
        // translations after the fact from the host UI).
        allow update: if isAuthenticated() &&
                      isValidMessage(request.resource.data) &&
                      request.resource.data.sessionId == sessionId &&
                      sessionHostId(sessionId) == request.auth.uid;
        allow delete: if isAuthenticated() &&
                      sessionHostId(sessionId) == request.auth.uid;
      }
    }
  }
}
